BACKEND_CORS_ORIGINS=http://localhost:3000
API_PORT=8000
JWT_SECRET_KEY=please-change-this-in-local-env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database:
# Use POSTGRES_URL when you have a Postgres instance. Otherwise the app falls back to a local SQLite file.
POSTGRES_URL=

DB_ECHO=false

# Model files:
MODEL_DIR=./model
DIABETES_MODEL_PATH=./model/diabetes_model.joblib
DIABETES_PREPROCESSOR_PATH=./model/diabetes_preprocessor.joblib

# AI provider:
# Set AI_PROVIDER to `openai`, `xai`, or `gemini`
AI_PROVIDER=openai

# OpenAI keys usually start with `sk-`
OPENAI_API_KEY=

# Gemini API keys can be kept separate here
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# xAI / Grok keys usually start with `gsk_`
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
OPENAI_MODEL=gpt-4o-mini
